# Python cache files — generated automatically, never commit these
__pycache__/
*.py[cod]
*.pyo

# Package build files
*.egg-info/
dist/
build/
*.egg

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Data files — too large for Git, user provides their own
*.tif
*.tiff
*.geotiff
data/
DATA/

# Output files — generated by the pipeline
output/

# Environment files
.env
*.env

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/